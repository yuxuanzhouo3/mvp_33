# Copy this file to .env.local before local development.
# Do not commit .env.local.

# ----------------------------------------------------------------------
# Core app URLs
# ----------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
GEO_FAIL_CLOSED=false
IP_API_URL=https://ipapi.co
NEXT_PUBLIC_DEMO_PREVIEW_PROVIDER=auto

# ----------------------------------------------------------------------
# Region selection
# Use CN for the CloudBase stack, INTL for the Supabase stack.
# The current project defaults to CN in most existing local setups.
# ----------------------------------------------------------------------
DEPLOYMENT_REGION=CN
NEXT_PUBLIC_DEPLOYMENT_REGION=CN
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh

# ----------------------------------------------------------------------
# Admin and session secrets
# Generate long random values for every *_SECRET field before real usage.
# ----------------------------------------------------------------------
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
CLOUDBASE_SESSION_SECRET=replace_with_a_long_random_secret
CLOUDBASE_SESSION_TTL=604800
MARKET_ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
MARKET_ADMIN_USERNAME=admin
MARKET_ADMIN_PASSWORD=replace_with_market_admin_password

# ----------------------------------------------------------------------
# CN stack: required when DEPLOYMENT_REGION=CN
# ----------------------------------------------------------------------
CLOUDBASE_ENV_ID=
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=
WECHAT_MINIPROGRAM_APPID=
WECHAT_MINIPROGRAM_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/oauth/wechat/callback

# ----------------------------------------------------------------------
# INTL stack: required when DEPLOYMENT_REGION=INTL
# ----------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL_CN=
NEXT_PUBLIC_SUPABASE_ANON_KEY_CN=

# ----------------------------------------------------------------------
# Auth email
# ----------------------------------------------------------------------
AUTH_EMAIL_SMTP_HOST=
AUTH_EMAIL_SMTP_PORT=465
AUTH_EMAIL_SMTP_USER=
AUTH_EMAIL_SMTP_PASS=
AUTH_EMAIL_FROM=

# ----------------------------------------------------------------------
# Market acquisition defaults
# Keep provider=file if you do not want live search during local dev.
# ----------------------------------------------------------------------
MARKET_LEAD_SOURCE_PROVIDER=file
MARKET_LEAD_SOURCE_FILE=config/market/acquisition-leads.json
SERPER_API_KEY=
TAVILY_API_KEY=
MARKET_LEAD_SOURCE_WEBHOOK_URL=
MARKET_PARTNER_OWNER_USER_ID=
MARKETING_PARTNER_USER_ID=

# ----------------------------------------------------------------------
# Market outreach email
# ----------------------------------------------------------------------
SMTP_CN_HOST=
SMTP_CN_PORT=465
SMTP_CN_USER=
SMTP_CN_PASS=
SMTP_INTL_HOST=
SMTP_INTL_PORT=465
SMTP_INTL_USER=
SMTP_INTL_PASS=

# ----------------------------------------------------------------------
# AI providers
# ----------------------------------------------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPAT_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_BASE_INTL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_COMPAT_BASE_INTL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALIYUN_QWEN_MODEL=qwen3.5-flash
ALIYUN_WAN_IMAGE_MODEL=wan2.5-t2i-preview
ALIYUN_WAN_VIDEO_MODEL=wan2.5-t2v-preview
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview

# ----------------------------------------------------------------------
# SMS / RTC / push
# ----------------------------------------------------------------------
ENABLE_REAL_SMS=false
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TPNS_CN_ACCESS_ID=
TPNS_CN_SECRET_KEY=
TPNS_CN_API_HOST=api.tpns.tencent.com
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_TRTC_SDK_APP_ID=
TENCENT_TRTC_SDK_APP_ID=
TENCENT_TRTC_SECRET_KEY=

# ----------------------------------------------------------------------
# Payments
# Leave blank unless you are testing that payment path.
# ----------------------------------------------------------------------
WECHAT_APP_ID=
WECHAT_MERCHANT_ID=
WECHAT_API_KEY=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=http://localhost:3000/api/payment/wechat/callback
WECHAT_SANDBOX=true
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----------------------------------------------------------------------
# OAuth
# ----------------------------------------------------------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------
# Direct publish integrations
# ----------------------------------------------------------------------
WECHAT_OA_ACCESS_TOKEN=
WECHAT_OA_APP_ID=
WECHAT_OA_APP_SECRET=
WECHAT_OA_THUMB_MEDIA_ID=
WECHAT_OA_AUTHOR=
WECHAT_OA_DIGEST=
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
MARKET_DOUYIN_CLIENT_KEY=
MARKET_DOUYIN_CLIENT_SECRET=
